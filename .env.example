# Get your free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use (free on Groq)
GROQ_MODEL=llama3-8b-8192

# Retrieval settings
TOP_K_RETRIEVAL=20       # how many chunks FAISS fetches initially
TOP_K_RERANK=5           # how many chunks go to the LLM after re-ranking
CHUNK_SIZE=500            # tokens per chunk
CHUNK_OVERLAP=50          # token overlap between consecutive chunks
